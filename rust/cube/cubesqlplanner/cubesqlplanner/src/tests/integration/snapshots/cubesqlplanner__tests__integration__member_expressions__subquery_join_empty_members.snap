---
source: cubesqlplanner/cubesqlplanner/src/tests/integration/member_expressions.rs
expression: sql
---
SELECT "top_orders".status "top_status" 
FROM  orders  AS "orders"
INNER JOIN (SELECT status, SUM(amount) FROM orders GROUP BY 1 ORDER BY 2 DESC LIMIT 2) AS "top_orders" ON "orders".status = "top_orders".status
GROUP BY 1
ORDER BY  1  ASC
